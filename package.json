{
  "name": "gravatar-worker",
  "type": "module",
  "version": "1.1.0-beta.1",
  "packageManager": "pnpm@11.5.0",
  "author": {
    "name": "ZL Asica",
    "email": "zl@zla.app",
    "url": "https://github.com/ZL-Asica/"
  },
  "license": "MIT",
  "funding": "https://github.com/sponsors/ZL-Asica",
  "homepage": "https://github.com/ZL-Asica/Gravatar-Worker",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZL-Asica/Gravatar-Worker.git"
  },
  "bugs": "https://github.com/ZL-Asica/Gravatar-Worker/issues",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings --strict-vars false",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "husky || true"
  },
  "dependencies": {
    "@jsquash/avif": "^2.1.1",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/webp": "^1.5.0",
    "@zl-asica/react": "^0.13.0",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@cloudflare/vite-plugin": "^1.22.1",
    "@eslint-react/eslint-plugin": "^5.8.8",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "vite": "^6.3.5",
    "vite-ssr-components": "^0.6.1",
    "wrangler": "^4.96.0"
  },
  "nano-staged": {
    "**/*.{js,jsx,ts,tsx,json,yml,css,scss,less,styl,html,md,mdx}": [
      "eslint --fix"
    ]
  }
}
